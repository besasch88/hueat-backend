meta {
  name: Get
  type: http
  seq: 1
}

get {
  url: http://127.0.0.1:8001/api/v1/tables/{{firstTableId}}/order
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

script:post-response {
  bru.setVar("firstCourseId", res.body?.item.courses[0]?.id);
  
}

settings {
  encodeUrl: true
  timeout: 0
}
